# Default data source for 2026 World Cup.
# free-2026 uses keyless public sources on the server side.
WORLD_CUP_DATA_SOURCE=free-2026

# Optional API-Football fallback. Keep this server-only and do not expose it with NEXT_PUBLIC_.
API_FOOTBALL_KEY=
API_FOOTBALL_SEASON=2026

# Optional DeepSeek key for AI-enhanced workflow generation.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional hot-signal sources. Keep all keys server-only.
TOPHUBDATA_API_KEY=
TOPHUBDATA_BASE_URL=https://api.tophubdata.com
TOPHUBDATA_NODE_HASHIDS=
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
DAILY_HOT_API_BASE=https://api-hot.imsyy.top
DAILY_HOT_PLATFORMS=weibo,douyin,bilibili,baidu,zhihu,hupu
