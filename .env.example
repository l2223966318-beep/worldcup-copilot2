# Optional Sportradar Soccer v4 source. Keep these server-only and do not expose them with NEXT_PUBLIC_.
# Data chain: Sportradar -> free-2026 public sources -> mock classic samples.
SPORTRADAR_API_KEY=
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_LANGUAGE_CODE=en
SPORTRADAR_BASE_URL=
SPORTRADAR_EXTENDED_BASE_URL=
SPORTRADAR_WORLD_CUP_COMPETITION_ID=
SPORTRADAR_WORLD_CUP_SEASON_ID=
SPORTRADAR_TIMEOUT_MS=5000

# Optional DeepSeek key for AI-enhanced workflow generation.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional hot-signal sources. Keep all keys server-only.
TOPHUBDATA_API_KEY=
TOPHUBDATA_BASE_URL=https://api.tophubdata.com
TOPHUBDATA_NODE_HASHIDS=
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
DAILY_HOT_API_BASE=https://api-hot.imsyy.top
DAILY_HOT_PLATFORMS=weibo,douyin,bilibili,baidu,zhihu,hupu

# UApiPro daily hot board. Keep the key server-only.
# The public hotboard endpoint can be tested without a key in some plans.
UAPIPRO_API_KEY=
UAPIPRO_BASE_URL=https://uapis.cn/api/v1
UAPIPRO_HOT_ENDPOINT=/misc/hotboard

# Optional Xiaohongshu hotspot source. If absent, the app falls back to Tavily public search.
XHS_HOT_API_URL=
XHS_HOT_API_KEY=

# Enable only when you intentionally want demo hotspot data.
NEXT_PUBLIC_USE_MOCK=false
